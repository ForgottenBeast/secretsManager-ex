{application,rotating_secrets,
             [{modules,['Elixir.Inspect.RotatingSecrets.Secret',
                        'Elixir.Jason.Encoder.RotatingSecrets.Secret',
                        'Elixir.RotatingSecrets',
                        'Elixir.RotatingSecrets.Registry',
                        'Elixir.RotatingSecrets.Secret',
                        'Elixir.RotatingSecrets.Source',
                        'Elixir.RotatingSecrets.Source.Env',
                        'Elixir.RotatingSecrets.Source.File',
                        'Elixir.RotatingSecrets.Source.Memory',
                        'Elixir.RotatingSecrets.Supervisor',
                        'Elixir.RotatingSecrets.Telemetry',
                        'Elixir.String.Chars.RotatingSecrets.Secret']},
              {optional_applications,[file_system,jason]},
              {applications,[kernel,stdlib,elixir,logger,telemetry,
                             file_system,jason]},
              {description,"Elixir secret lifecycle library with rotation, borrow semantics, and pluggable sources"},
              {registered,[]},
              {vsn,"0.1.0"}]}.
